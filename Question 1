numbers=[2, 4, 7, 10, 15, 23, 29, 35, 49, 53]
print("Prime number in the list")
for num in numbers:
    if num <= 1:
        continue

    is_prime = True

    for i in range(2, int(num**0.5) + 1):
        if num % i == 0:
            is_prime = False
            break
    if is_prime:
        print(num)
